@model ApplicationUser
<link rel="stylesheet" href="~/css/dab.css" />
<div class="main_page col-12">
    <!--head starts-->
    <div class="head shadow-sm col-12">
        <div class="left_head">
            <i class="fa-solid fa-bars i_title" id="icon_title"></i>
        </div>
        <div class="right_head">
            <div class="right_head_profile">
                <p class="p_prof">Welcome, @Model.UserName</p>
                <div id="open_prof" class="img_prof" style="background-image:url('@Url.Content("~/images/"+Model.ImageUrl)')"></div>
            </div>
        </div>
    </div>
    <!--head ends-->
    <div class="main_area col-10">
        <div class="upper_content col-12">
            <h4>Dashboard</h4>
        </div>

        <div class="main_inform col-12">
            <!-- first -->
            <div class="inform_box shadow-sm">
                <div class="left_box">
                    <h4 class="h_box">45</h4>
                    <p class="p_box">Flights Booked</p>
                </div>
                <i class="fa-regular fa-calendar i_calender"></i>
            </div>
            <!-- second -->
            <div class="inform_box shadow-sm">
                <div class="left_box">
                    <h4 class="h_box">33</h4>
                    <p class="p_box">Flights Done</p>
                </div>
                <i class="fa-solid fa-check i_success"></i>
            </div>
            <!-- third -->
            <div class="inform_box shadow-sm">
                <div class="left_box">
                    <h4 class="h_box">12</h4>
                    <p class="p_box">Flights Cancelled</p>
                </div>
                <i class="fa-solid fa-xmark i_cancel"></i>
            </div>
            <!-- fourth -->
            <div class="inform_box shadow-sm">
                <div class="left_box">
                    <h4 class="h_box">13,105</h4>
                    <p class="p_box">Total Spend</p>
                </div>
                <i class="fa-solid fa-money-bills i_money"></i>
            </div>
        </div>
        <!--lower starts-->
        <div class="lower_content col-12">
            <!-- lower left starts -->
            <div class="lower_left">
                <p class="p_lower_left">Latest Tickets Sold</p>
                <table class="table table-striped" style="margin-bottom: 0;">
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Email</th>
                            <th scope="col">Form</th>
                            <th scope="col">To</th>
                            <th scope="col">Price</th>
                            <th scope="col">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>when</td>
                            <td>
                                <i class="fa-regular fa-envelope i_mail"></i>
                                ahmed@gmail
                            </td>
                            <td>Otto</td>
                            <td>when</td>
                            <td>Mark</td>
                            <td>
                                <div class="div_paid">
                                    <i class="fa-regular fa-circle-check i_paid"></i>
                                    <p class="p_status">Paid</p>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td>when</td>
                            <td>
                                <i class="fa-regular fa-envelope i_mail"></i>
                                ahmed@gmail
                            </td>
                            <td>Otto</td>
                            <td>when</td>
                            <td>Mark</td>
                            <td>
                                <div class="div_cancel">
                                    <i class="fa-solid fa-circle-exclamation"></i>
                                    <p class="p_status">Unpaid</p>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <!-- lower left ends -->
            <!-- lower rigth starts -->
            <div class="lower_right">
                <div class="lower_right_chart shadow-sm col-12">
                    <h5>Most Vistited Cities</h5>
                    <canvas id="cityChart" class="chart "></canvas>
                </div>
                <div class="vip_div shadow-sm col-12">
                    <h6>V.I.P Passengers</h6>
                    <div class="person_div col-12">
                        <div class="left_person">
                            <div class="img_person" style="background-image:url('@Url.Content("~/images/profile.jpg")')"></div>
                            <div class="inf_pers">
                                <p class="p_inf_pers">Name</p>
                                <p class="p_inf_pers">Email</p>
                            </div>
                        </div>
                        <p class="p_person_des">20 Miles</p>
                        <i class="fa-solid fa-circle-info i_person"></i>
                        <div class="line_person col-12"></div>
                    </div>
                </div>
            </div>
            <!-- lower rigth ends -->
        </div>
        <!--lower ends-->
    </div>
    <!-- left nav fixed started -->
</div>

<!--Nav fixed starts-->
<div class="nav_page col-12">
    <div class="left_nav">
        <div class="nav_title col-12">
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="h_nav">AirLines</a>
            <i class="fa-solid fa-xmark a_nav_title"></i>
        </div>
        <div class="nav_content col-12">
            <div class="content col-12" style="background-color: #80808054;">
                <a href="#" class="a_nav"><i class="fa-solid fa-grip"></i> Dashboard</a>
            </div>
            <div class="content col-12" id="table_content">
                <p href="#" class="a_nav"><i class="fa-solid fa-table"></i> Tables</p>
                <i class="fa-solid fa-caret-right i_nav"></i>
            </div>
            <div class="mini_content col-12">
                <div class="content col-12">
                    <a href="#" class="a_nav">Country</a>
                </div>
                <div class="content col-12">
                    <a href="#" class="a_nav">City</a>
                </div>
                <div class="content col-12">
                    <a href="#" class="a_nav">Category</a>
                </div>
                <div class="content col-12">
                    <a href="#" class="a_nav">Ticket</a>
                </div>
                <div class="content col-12">
                    <a href="#" class="a_nav">Trip</a>
                </div>
                <div class="content col-12">
                    <a href="#" class="a_nav">Company</a>
                </div>
                <div class="content col-12">
                    <a href="#" class="a_nav">Passenger and Mates</a>
                </div>
                <div class="content col-12">
                    <a href="#" class="a_nav">Seats</a>
                </div>
            </div>
            <div class="content col-12">
                <a href="#" class="a_nav"><i class="fa-regular fa-money-bill-1"></i> Payments</a>
            </div>
            <div class="content col-12">
                <a href="#" class="a_nav"><i class="fa-solid fa-users"></i> Users</a>
            </div>
        </div>
        <div class="lower_nav col-12">
            <div class="content col-12">
                <a href="#" class="a_nav"><i class="fa-regular fa-user"></i> Profile</a>
            </div>
            <div class="content col-12">
                <a asp-area="Identity" asp-controller="Account" asp-action="Logout" class="a_nav"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</a>
            </div>
        </div>
    </div>
</div>
<!--Nav fixed ends-->
@section Scripts {
    <script>

        const labels = ["Paris %", "France %", "England"];
        const data = [50, 30, 0]; // Example counts

        new Chart(document.getElementById('cityChart'), {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: ['blue', '#FFCE56', 'green'],
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'right'
                    }
                }
            }
        });

        const icon_title = document.querySelector('#icon_title');
        const table_content = document.querySelector('#table_content');
        const nav_page = document.querySelector('.nav_page');
        const main_page = document.querySelector('.main_page');
        const left_nav = document.querySelector('.left_nav');
        const mini_content = document.querySelector('.mini_content');
        const i_nav = document.querySelector('.i_nav');
        const a_nav_title = document.querySelector('.a_nav_title');

        icon_title.onclick = function () {
            nav_page.style.display = "block";
            setTimeout(function () {
                left_nav.classList.add("left_nav_appear");
            }, 200)
        };

        nav_page.onclick = function () {
            nav_page.style.display = "none";
            if (i_nav.classList.contains("i_nav_rotate")) {
                i_nav.classList.remove("i_nav_rotate");
                mini_content.style.display = "none";
            }
            left_nav.classList.remove("left_nav_appear");
        };
        left_nav.onclick = function (e) {
            e.stopPropagation();
        };
        table_content.onclick = function () {
            if (i_nav.classList.contains("i_nav_rotate")) {
                i_nav.classList.remove("i_nav_rotate");
                mini_content.style.display = "none";
            } else {
                i_nav.classList.add("i_nav_rotate");
                mini_content.style.display = "flex";
            }
        }
        a_nav_title.onclick = function () {
            nav_page.style.display = "none";
        }
    </script>
}